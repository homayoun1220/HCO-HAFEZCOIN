\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Adversarial influence share vs.\ channel capacity $m$, for $s\in \{400,700,1000\}$ and $n_{\rm  honest}=200$. All curves overlap: influence share equals $m/(m+n)$, independent of $s$. Identity replication alone cannot increase influence; additional influence requires additional throughput channels (Theorem\nonbreakingspace \ref {thm:linear}).\relax }}{16}{figure.caption.6}\protected@file@percent }
\newlabel{fig:influence_share}{{2}{16}{Adversarial influence share vs.\ channel capacity $m$, for $s\in \{400,700,1000\}$ and $n_{\rm honest}=200$. All curves overlap: influence share equals $m/(m+n)$, independent of $s$. Identity replication alone cannot increase influence; additional influence requires additional throughput channels (Theorem~\ref {thm:linear}).\relax }{figure.caption.6}{}}
